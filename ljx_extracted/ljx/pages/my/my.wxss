/* pages/my/my.wxss */
.avatar-container{
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fff;
}
.user-info{
  display: flex;
  align-items: center;
}
.user-detail{
  display: flex;
  flex-direction: column;
}
.avatar{
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}
.username{
  margin-left: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.personal{
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}
.icons{
  display: flex;
  align-items: center;
}
.icon{
  width: 50rpx;
  height: 50rpx;
  margin-left: 30rpx;
}
/* 统计数据容器 */
.stats-container{
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}
.stat-item{
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-label{
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}
.stat-num{
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
/* 分隔线 */
.divider{
  padding-top: 10rpx;
  width: 5rpx;
  height: 60rpx;
  background: #e0e0e0;
}
/* 菜单项目 */
.menu-item-1{
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-top: 5rpx solid #f0f0f0;
  background: #fff;
  margin-top: 20rpx;
}
.menu-item-2{
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-top: 40rpx solid #f0f0f0;
  background: #fff;
  margin-top: 20rpx;
}
.menu-left{
  display: flex;
  align-items: center;
}
.menu-icon{
  width: 48rpx;
  height: 48rpx;
}
.menu-text{
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #333;
}
.menu-arrow{
  width: 40rpx;
  height: 40rpx;
}