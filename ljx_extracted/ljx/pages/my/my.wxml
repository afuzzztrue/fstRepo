<!--pages/my/my.wxml-->
<view>
  <view class="avatar-container">
    <view class="user-info">
      <image class="avatar" src="../images/kk.png" />
      <view class="user-detail">
        <text class="username" bindtap="goToLogin">未登录</text>
        <text class="personal">点击登录</text>
      </view>
    </view>
    <view class="icons">
      <image class="icon" src="../images/set.png" />
      <image class="icon" src="../images/saearch.png" />
    </view>
  </view>

  <view class="stats-container">
    <view class="stat-item">
      <text class="stat-label">关注</text>
      <text class="stat-num">50</text>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="stat-label">收藏</text>
      <text class="stat-num">60</text>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="stat-label">学习时间</text>
      <text class="stat-num">1000小时</text>
    </view>
  </view>

  <view class="menu-item-1">
    <view class="menu-left">
      <image class="menu-icon" src="../images/足迹.png" />
      <text class="menu-text">我的足迹</text>
    </view>
    <image class="menu-arrow" src="../images/向右箭头.png" />
  </view>

  <view class="menu-item-1">
    <view class="menu-left">
      <image class="menu-icon" src="../images/我的作品.png" />
      <text class="menu-text">我的作品</text>
    </view>
    <image class="menu-arrow" src="../images/向右箭头.png" />
  </view>

  <view class="menu-item-1">
    <view class="menu-left">
      <image class="menu-icon" src="../images/下载.png" />
      <text class="menu-text">已下载的课程</text>
    </view>
    <image class="menu-arrow" src="../images/向右箭头.png" />
  </view>

  <view class="menu-item-1">
    <view class="menu-left">
      <image class="menu-icon" src="../images/点赞.png" />
      <text class="menu-text">我的点赞</text>
    </view>
    <image class="menu-arrow" src="../images/向右箭头.png" />
  </view>

  <view class="menu-item-2">
    <view class="menu-left">
      <image class="menu-icon" src="../images/帮助与反馈.png" />
      <text class="menu-text">帮助与反馈</text>
    </view>
    <image class="menu-arrow" src="../images/向右箭头.png" />
  </view>

  <view class="menu-item-1">
    <view class="menu-left">
      <image class="menu-icon" src="../images/客服.png" />
      <text class="menu-text">客服中心</text>
    </view>
    <image class="menu-arrow" src="../images/向右箭头.png" />
  </view>

</view>