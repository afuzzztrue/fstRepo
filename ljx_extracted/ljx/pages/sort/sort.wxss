/* pages/sort/sort.wxss */
.modle-title{
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #222222;
}
.sort-title{
  display: flex;
  align-items: center;
}
.sort-images{
  width: 50rpx;
  height: 50rpx;
  margin-right: 15rpx;
}
.title{
  font-size: 44rpx;
  font-weight: bold;
  color: #8B4513;
}
.search-bar{
  width: 280rpx;
  display: flex;
  align-items: center;
}
.search-icon{
  width: 40rpx;
  height: 40rpx;
  position: absolute;
  margin-left: 20rpx;
  z-index: 10;
}
.search-input{
  width: 320rpx;
  background: #f5f5f5;
  height: 70rpx;
  border-radius: 35rpx;
  padding: 0 60rpx;
  font-size: 28rpx;
  border: 2rpx solid #8B4513;
}
/* 分栏 */
.category-scroll{
  white-space: nowrap;
  background: #fff;
}
.category-list{
  display: inline-flex;
  padding: 20rpx;
}
.category-item{
  padding: 15rpx 40rpx;
  margin-right: 20rpx;
  background: #DEB887;
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #5D4037;
}
.category-item.active{
  background: #F5E6D3;
  font-weight: bold;
}
/* 卡片区域 */
.card-area{
  padding: 30rpx;
  background: #F5EDE4;
}
.card-list{
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 30rpx;
}
.card-item{
  width: 40%;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
}
.card-image{
  width: 100%;
  height: 250rpx;
  border-radius: 10rpx;
}
.card-title{
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-top: 15rpx;
}