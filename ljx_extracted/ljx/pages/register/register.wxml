<!--pages/register/register.wxml-->
<view class="register-container">
  <view class="title">注册账号</view>
  <view class="subtitle">加入我们，一起传承非遗文化</view>

  <view class="form">
    <input class="input" placeholder="请输入手机号/邮箱" />
    <input class="input" placeholder="请输入验证码" />
    <input class="input" placeholder="请设置密码" password />
    <input class="input" placeholder="请确认密码" password />
  </view>

  <button class="btn-register">注册</button>

  <view class="footer">
    <text class="text">已有账号？</text>
    <text class="link" bindtap="goToLogin">立即登录</text>
  </view>
</view>