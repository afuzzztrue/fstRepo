<!--pages/register/register.wxml-->
<view class="register-container">
  <view class="title">注册账号</view>
  <view class="subtitle">加入我们，一起传承非遗文化</view>

  <view class="form">
    <input class="input" placeholder="请输入手机号/邮箱" bindinput="inputAccount" value="{{account}}" />
    <input class="input" placeholder="请输入昵称" bindinput="inputNickname" value="{{nickname}}" />
    <input class="input" placeholder="请设置密码" password bindinput="inputPassword" value="{{password}}" />
    <input class="input" placeholder="请确认密码" password bindinput="inputConfirmPassword" value="{{confirmPassword}}" />
  </view>

  <button class="btn-register" bindtap="doRegister">注册</button>

  <view class="footer">
    <text class="text">已有账号？</text>
    <text class="link" bindtap="goToLogin">立即登录</text>
  </view>
</view>
