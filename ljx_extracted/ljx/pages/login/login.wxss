/* pages/login/login.wxss */
.login-container{
  padding: 80rpx 60rpx;
  background: #F5EDE4;
  min-height: 100vh;
}
.title{
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}
.subtitle{
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 80rpx;
}
.form{
  margin-bottom: 40rpx;
}
.input{
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  font-size: 28rpx;
}
.btn-login{
  background: #8B4513;
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}
.footer{
  display: flex;
  justify-content: center;
  align-items: center;
}
.text{
  font-size: 26rpx;
  color: #999;
}
.link{
  font-size: 26rpx;
  color: #8B4513;
  margin-left: 10rpx;
}